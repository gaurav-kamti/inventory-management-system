# DATABASE CONFIGURATION
# For Local Development: 
# Just leave this commented out and the app will use database.sqlite automatically.

# For Production (Supabase / Render):
# DATABASE_URL=postgres://user:password@host:port/dbname

# AUTHENTICATION
JWT_SECRET=your_super_secret_key_change_me_in_production

# CLOUDFLARE CONFIGURATION (OPTIONAL)
# If using Cloudflare R2 for Product Images
# CF_ACCOUNT_ID=your_account_id
# CF_ACCESS_KEY_ID=your_access_key
# CF_SECRET_ACCESS_KEY=your_secret_key
# CF_BUCKET_NAME=inventory-images

# APP SETTINGS
PORT=5000
NODE_ENV=production
